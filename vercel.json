{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd graduate_intelligence_platform/frontend && npm install && npm run build",
  "outputDirectory": "graduate_intelligence_platform/frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://your-railway-backend.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_URL": "@vite_api_url"
  }
}
