# Local-only example for Railway data sync.
# Copy to .env.local and replace placeholders. Never commit real secrets.

RAILWAY_DATABASE_URL=postgresql://postgres:<PASSWORD>@ballast.proxy.rlwy.net:59250/railway
RAILWAY_DB_SSLMODE=require

LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=5433
LOCAL_DB_NAME=cliente_a_db
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=<LOCAL_PASSWORD>
LOCAL_DB_SSLMODE=prefer

API_BASE_URL=https://graduate-intelligence-platform-production.up.railway.app

# Optional only when running inside Railway where DB_* points to the production database.
# Keep disabled in local development to avoid confusing DB_* local variables with Railway.
ALLOW_DB_ENV_TARGET=false
